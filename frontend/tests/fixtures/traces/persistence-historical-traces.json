[
	{
		"id": "2026-04-14-finalized-tmp-assistant-drop",
		"description": "Historical regression: stale get_messages replay between stream.done and agent.idle dropped finalized assistant turn.",
		"initialSessionId": "sess-a",
		"steps": [
			{
				"type": "event",
				"event": {
					"channel": "agent",
					"session_id": "sess-a",
					"event": "stream.message_start",
					"role": "assistant"
				}
			},
			{
				"type": "event",
				"event": {
					"channel": "agent",
					"session_id": "sess-a",
					"event": "stream.text_delta",
					"message_id": "tmp:a1",
					"delta": "Draft answer"
				}
			},
			{
				"type": "event",
				"event": {
					"channel": "agent",
					"session_id": "sess-a",
					"event": "stream.done",
					"message_id": "tmp:a1"
				}
			},
			{
				"type": "event",
				"event": {
					"channel": "agent",
					"session_id": "sess-a",
					"event": "response",
					"id": "r-old-1",
					"cmd": "get_messages",
					"success": true,
					"data": {
						"messages": [
							{
								"id": "h-u1",
								"role": "user",
								"content": "question",
								"timestamp": 1000
							}
						],
						"message_version": { "version": 1 }
					}
				}
			},
			{
				"type": "event",
				"event": {
					"channel": "agent",
					"session_id": "sess-a",
					"event": "agent.idle",
					"message_version": { "version": 2 }
				}
			},
			{ "type": "advance", "ms": 250 }
		],
		"historyFetches": [
			[
				{
					"id": "h-u1",
					"role": "user",
					"content": "question",
					"timestamp": 1000,
					"client_id": "c-1"
				},
				{
					"id": "h-a1",
					"role": "assistant",
					"content": "final answer",
					"timestamp": 2000
				}
			]
		],
		"expected": [
			{ "id": "h-u1", "role": "user", "text": "question" },
			{ "id": "h-a1", "role": "assistant", "text": "final answer" }
		]
	},
