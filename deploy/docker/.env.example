# =============================================================================
# Oqto Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider API Keys (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# AZURE_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=

# --- Authentication ---
# JWT secret for token signing. Auto-generated and persisted if unset.
# For production: generate with `openssl rand -hex 32`
# JWT_SECRET=

# Admin user created on first boot. Password auto-generated if unset.
# ADMIN_USER=admin
# ADMIN_PASSWORD=
# ADMIN_EMAIL=admin@oqto.local

# --- Networking ---
# Port exposed to the host
# OQTO_PORT=8080

# --- Mode ---
# Set to "true" to skip authentication (single-user/dev mode)
# OQTO_SINGLE_USER=false

# --- Logging ---
# Options: error, warn, info, debug, trace
# OQTO_LOG_LEVEL=info
