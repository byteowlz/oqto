# =============================================================================
# Oqto Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider API Keys (at least one required, unless using local LLM) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# AZURE_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=

# --- Local LLM (Ollama, LM Studio, llama.cpp, vLLM, etc.) ---
# Any OpenAI-compatible server. No API key needed for most local servers.
# On Docker Desktop (Mac/Windows): use http://host.docker.internal:<port>
# On Linux with --network=host: use http://localhost:<port>
#
# Examples:
#   LOCAL_LLM_URL=http://host.docker.internal:11434  # Ollama on host (Mac/Windows)
#   LOCAL_LLM_URL=http://host.docker.internal:1234   # LM Studio on host
#   LOCAL_LLM_URL=http://host.docker.internal:8080   # llama.cpp / vLLM on host
#   LOCAL_LLM_URL=http://100.x.y.z:11434             # Remote machine via Tailscale IP
#   LOCAL_LLM_URL=http://192.168.1.100:11434         # Remote machine on LAN
#
# LOCAL_LLM_URL=

# --- Authentication ---
# JWT secret for token signing. Auto-generated and persisted if unset.
# For production: generate with `openssl rand -hex 32`
# JWT_SECRET=

# Admin user created on first boot.
# IMPORTANT: The web UI still uses a login screen in Docker mode.
# Set ADMIN_PASSWORD explicitly so you always know the credentials.
# If ADMIN_PASSWORD is left empty, a random password is generated and printed once in logs.
# ADMIN_USER=admin
# ADMIN_PASSWORD=change-me-please-32chars-min
# ADMIN_EMAIL=admin@oqto.local

# --- Networking ---
# Port exposed to the host
# OQTO_PORT=8080

# --- Mode ---
# Docker mode currently defaults to single-user (skips auth, personal/dev use).
# Set to false only on real Linux host deployments with full multi-user runtime.
# OQTO_SINGLE_USER=true

# --- Data ---
# Where to store all persistent data (databases, secrets, workspaces).
# Default: Docker named volume "oqto-data" (managed by Docker).
# Set to a host path (e.g. ./data or /srv/oqto) to use a bind mount instead.
# OQTO_DATA_PATH=./data

# --- Logging ---
# Options: error, warn, info, debug, trace
# OQTO_LOG_LEVEL=info
