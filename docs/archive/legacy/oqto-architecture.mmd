    style Backend fill:#5cb85c,stroke:#4cae4c,color:#fff
    style Runner fill:#f0ad4e,stroke:#eea236,color:#000
    style Agents fill:#d9534f,stroke:#d43f3a,color:#fff
    style Services fill:#9b59b6,stroke:#8e44ad,color:#fff
