flowchart TB
    subgraph Frontend["Frontend (React/TypeScript)"]
        UI["Chat UI"]
        FileViewer["File Viewer"]
        Terminal["Terminal"]
    end

    subgraph Backend["Backend (oqto)"]
        WSHandler["WebSocket Handler"]
        SessionMgr["Session Manager"]
        EAVSClient["EAVS Client"]
    end

    subgraph Runner["Runner (oqto-runner)"]
        RunnerSocket["Unix/TCP Socket"]
        Translator["PiTranslator"]
        ProcessMgr["Process Manager"]
    end

    subgraph Agents["Agent Processes"]
        Pi1["Pi Session A"]
        Pi2["Pi Session B"]
        Future["Future Harnesses"]
    end

    subgraph Services["Services"]
        Hstry["hstry (gRPC + SQLite)"]
        EAVS["EAVS (LLM Proxy)"]
        FileServer["oqto-files"]
    end

    UI <-->|"Multiplexed WS<br/>agent / files / terminal"| WSHandler
    FileViewer <-->|"files channel"| WSHandler
    Terminal <-->|"terminal channel"| WSHandler

    WSHandler <-->|"Canonical Protocol<br/>Commands & Events"| RunnerSocket
    WSHandler <-->|"Read/Write Messages"| Hstry
    WSHandler <-->|"Model metadata & keys"| EAVSClient

    EAVSClient <-->|"Virtual keys / quotas"| EAVS

    RunnerSocket -->|"Native Events"| Translator
    Translator -->|"Canonical Events"| RunnerSocket

    ProcessMgr -->|"Spawn"| Pi1
    ProcessMgr -->|"Spawn"| Pi2
    ProcessMgr -.->|"Future"| Future

    Pi1 <-->|"stdout/stdin JSON"| Translator
    Pi2 <-->|"stdout/stdin JSON"| Translator

    Pi1 -.->|"Session files"| LocalStorage[("~/.pi/agent/sessions/")]
    Hstry -.->|"Chat history"| SQLite[("SQLite")]

    FileServer <-->|"File operations"| WSHandler

